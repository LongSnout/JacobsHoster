                          <Label styleClass="ficha-title" text="Productos" />
                          <Separator />
                          <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                      styleClass="ventas-scroll">
                            <content>
                              <ListView fx:id="lvProductosCatalogo" />
                            </content>
                          </ScrollPane>
                          <GridPane hgap="8.0" vgap="6.0">
                            <columnConstraints>
                              <ColumnConstraints minWidth="80.0" prefWidth="80.0" />
                              <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                              <Label text="Nombre" styleClass="ficha-label"
                                     GridPane.rowIndex="0" GridPane.columnIndex="0" />
                              <TextField fx:id="tfNombreProducto" promptText="Ej: Concha"
                                         maxWidth="1.7976931348623157E308"
                                         GridPane.rowIndex="0" GridPane.columnIndex="1" />
                              <Label text="Precio €" styleClass="ficha-label"
                                     GridPane.rowIndex="1" GridPane.columnIndex="0" />
                              <TextField fx:id="tfPrecioProducto" promptText="0.00"
                                         maxWidth="1.7976931348623157E308"
                                         GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            </children>
                            <rowConstraints>
                              <RowConstraints /><RowConstraints />
                            </rowConstraints>
                          </GridPane>
                          <HBox spacing="6.0">
                            <children>
                              <Button text="Nuevo" onAction="#onNuevoProductoCatalogo" styleClass="btn-copiar" />
                              <Button text="Guardar" onAction="#onGuardarProductoCatalogo" styleClass="btn-guardar" />
                              <Button text="Desactivar" onAction="#onDesactivarProductoCatalogo" styleClass="btn-eliminar" />
                            </children>
                          </HBox>
                        </children>
                      </VBox>

                    </HBox>

                    <!-- Resumen del día con GridPane de dos columnas iguales -->
                    <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="ficha-section">
                      <children>
                        <Label styleClass="ficha-title" text="Resumen del día" />
                        <Separator />
                        <GridPane hgap="20.0" vgap="6.0" HBox.hgrow="ALWAYS">
                          <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                          </columnConstraints>
                          <children>
                            <!-- Columna izquierda: totales -->
                            <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                              <children>
                                <Label fx:id="lblResumenEstancias" text="Estancias:   0,00 €"
                                       styleClass="ventas-resumen-item" />
                                <Label fx:id="lblResumenProductos" text="Productos:  0,00 €"
                                       styleClass="ventas-resumen-item" />
                                <Separator />
                                <Label fx:id="lblResumenTotal" text="Total:  0,00 €"
                                       styleClass="ventas-resumen-total" />
                              </children>
                            </VBox>
                            <!-- Columna derecha: desglose dinámico -->
                            <VBox fx:id="vboxResumenPorTipo" spacing="4.0"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0" />
                          </children>
                          <rowConstraints>
                            <RowConstraints />
                          </rowConstraints>
                        </GridPane>
                      </children>
                    </VBox>

                  </VBox>
                </children>
