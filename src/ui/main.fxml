<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Hyperlink?>





<BorderPane prefHeight="400.0" prefWidth="600.0"
            styleClass="app-root"
            stylesheets="@styles/app.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController">

   <top>
      <MenuBar>
        <menus>
          <Menu fx:id="menuArchivo" mnemonicParsing="false" text="Archivo">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#onCerrarSesion" text="Cerrar sesión" />
            </items>
          </Menu>
          <Menu fx:id="menuEdicion" mnemonicParsing="false" text="Edición">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#onAjustarCarpetaXML" text="Ajustar carpeta XML" />
              <MenuItem mnemonicParsing="false" onAction="#onEditarAlbergue" text="Editar albergue" />
            </items>
          </Menu>
          <Menu fx:id="menuAyuda" mnemonicParsing="false" text="Ayuda">
    		<items>
        		<MenuItem mnemonicParsing="false" onAction="#onAbrirManual" text="Manual de usuario" />
    		</items>
		  </Menu>
          <Menu fx:id="menuPerfiles" mnemonicParsing="false"  text="Perfiles">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#onGestionPerfiles" text="Gestionar perfiles" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>

   <center>
      <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>

          <!-- ===================================================== -->
          <!-- PESTAÑA: ESTANCIAS                                      -->
          <!-- ===================================================== -->
          <Tab text="Estancias">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0">
                <children>
                  <HBox spacing="7.0"
                        AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0"
                        AnchorPane.rightAnchor="0.0"
                        AnchorPane.topAnchor="0.0">
                    <padding>
                      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>

                    <!-- Panel izquierdo -->
                    <VBox prefWidth="220.0" spacing="6.0" styleClass="left-panel">
                      <children>
                        <HBox spacing="4.0">
                          <children>
                            <Button fx:id="btnDiaAnterior" mnemonicParsing="false" onAction="#onDiaAnterior" text="◀" />
                            <DatePicker fx:id="dpFechaLista" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnDiaSiguiente" mnemonicParsing="false" onAction="#onDiaSiguiente" text="▶" />
                          </children>
                        </HBox>
                        <TextField fx:id="tfBuscarHuesped" promptText="Buscar (nombre, DNI...)" />
                        <ListView fx:id="lvHuespedes" VBox.vgrow="ALWAYS" />
                        <Label fx:id="lblPlazas" text="Plazas ocupadas: 0 / 0" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                onAction="#onExportarXMLMinisterio"
                                prefHeight="26.0" styleClass="btn-exportar"
                                text="Exportar XML Ministerio" VBox.vgrow="NEVER" />
                      </children>
                    </VBox>

                    <!-- Panel ficha -->
                    <BorderPane styleClass="ficha-shell" HBox.hgrow="ALWAYS">

                      <center>
                        <ScrollPane fx:id="spFicha" fitToWidth="true" hbarPolicy="NEVER"
                                    BorderPane.alignment="CENTER">
                          <content>
                            <VBox maxWidth="1.7976931348623157E308" spacing="14.0" styleClass="ficha-root">
                              <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                              </padding>
                              <children>

                                <!-- Datos mínimos Ministerio -->
                                <VBox spacing="8.0" styleClass="ficha-section">
                                  <children>
                                    <Label focusTraversable="false" styleClass="ficha-title"
                                           text="Datos mínimos Ministerio de Interior" />
                                    <Separator />
                                    <GridPane hgap="10.0" vgap="8.0">
                                      <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="170.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                      </columnConstraints>
                                      <children>
                                        <Label focusTraversable="false" styleClass="ficha-label" text="DNI/NIF/NIE/PAS/OTRO/CIF/CIF_E" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="tfTipoDocumento" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Número de documento" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="tfNumeroDocumento" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="tfNombre" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Apellido 1" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="tfApellido1" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Apellido 2" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="tfApellido2" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Fecha de nacimiento" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <TextField fx:id="tfFechaNacimiento" maxWidth="1.7976931348623157E308" promptText="dd/MM/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Sexo (H/M/O)" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <TextField fx:id="tfSexo" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Nacionalidad (ISO3)" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                        <TextField fx:id="tfNacionalidad" maxWidth="1.7976931348623157E308" promptText="ESP" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                      </children>
                                      <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                      </rowConstraints>
                                    </GridPane>
                                    <Separator />
                                    <Label focusTraversable="false" styleClass="ficha-title" text="Dirección" />
                                    <GridPane hgap="10.0" vgap="8.0">
                                      <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="170.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                      </columnConstraints>
                                      <children>
                                        <Label focusTraversable="false" styleClass="ficha-label" text="País (ISO3)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="tfPais" maxWidth="1.7976931348623157E308" promptText="ESP" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Código postal" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="tfCodigoPostal" maxWidth="1.7976931348623157E308" promptText="#####" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Dirección" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="tfDireccion" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Código municipio (ESP)" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="tfCodigoMunicipio" maxWidth="1.7976931348623157E308" promptText="#####" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Municipio (no ESP)" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="tfNombreMunicipio" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                      </children>
                                      <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                      </rowConstraints>
                                    </GridPane>
                                  </children>
                                </VBox>

                                <!-- Estancia -->
                                <VBox spacing="8.0" styleClass="ficha-section">
                                  <children>
                                    <Label focusTraversable="false" styleClass="ficha-title" text="Estancia" />
                                    <Separator />
                                    <GridPane hgap="10.0" vgap="8.0">
                                      <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="170.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                      </columnConstraints>
                                      <children>
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Referencia" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="tfReferencia" editable="false" focusTraversable="false" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Fecha entrada" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="tfFechaEntrada" maxWidth="1.7976931348623157E308" promptText="dd/MM/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Fecha salida" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="tfFechaSalida" maxWidth="1.7976931348623157E308" promptText="dd/MM/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Nº habitaciones" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="tfNumHabitaciones" maxWidth="1.7976931348623157E308" promptText="1" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Internet" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <CheckBox fx:id="cbInternet" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Referencia de grupo" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <TextField fx:id="tfNumPersonas" maxWidth="1.7976931348623157E308" promptText="Ej: Grupo1" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Nº habitación" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <TextField fx:id="tfNumeroHabitacion" maxWidth="1.7976931348623157E308" promptText="Ej: 3" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Nº cama" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                        <TextField fx:id="tfNumeroCama" maxWidth="1.7976931348623157E308" promptText="Ej: 2" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Inicio del camino" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                                        <TextField fx:id="tfLugarInicioCamino" maxWidth="1.7976931348623157E308" promptText="Ej: Irún" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Último albergue" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                                        <TextField fx:id="tfUltimoAlbergue" maxWidth="1.7976931348623157E308" promptText="Ej: Albergue de Tineo" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Camino destino" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                                        <TextField fx:id="tfCaminoDestino" maxWidth="1.7976931348623157E308" promptText="Ej: Primitivo" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Fecha contrato" GridPane.columnIndex="0" GridPane.rowIndex="11" />
                                        <TextField fx:id="tfFechaContrato" maxWidth="1.7976931348623157E308" promptText="dd/MM/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                                      </children>
                                      <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                      </rowConstraints>
                                    </GridPane>
                                  </children>
                                </VBox>

                                <!-- Pago -->
                                <VBox spacing="8.0" styleClass="ficha-section">
                                  <children>
                                    <Label focusTraversable="false" styleClass="ficha-title" text="Pago" />
                                    <Separator />
                                    <GridPane hgap="10.0" vgap="8.0">
                                      <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="170.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                      </columnConstraints>
                                      <children>
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Tipo de pago" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="tfTipoPago" maxWidth="1.7976931348623157E308" promptText="EFECT / TARJT / ..." GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Titular" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="tfTitular" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Caducidad tarjeta" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="tfCaducidadTarjeta" maxWidth="1.7976931348623157E308" promptText="mm/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Medio de pago" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="tfMedioPago" maxWidth="1.7976931348623157E308" promptText="Ej: metálico / TPV / app" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Fecha de pago" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="tfFechaPago" maxWidth="1.7976931348623157E308" promptText="dd/MM/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                      </children>
                                      <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                      </rowConstraints>
                                    </GridPane>
                                  </children>
                                </VBox>

                                <!-- Extras -->
                                <VBox spacing="8.0" styleClass="ficha-section">
                                  <children>
                                    <Label focusTraversable="false" styleClass="ficha-title" text="Extras (opcionales)" />
                                    <Separator />
                                    <GridPane hgap="10.0" vgap="8.0">
                                      <columnConstraints>
                                        <ColumnConstraints minWidth="170.0" prefWidth="170.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                      </columnConstraints>
                                      <children>
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Soporte documento" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="tfSoporteDocumento" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Dirección complementaria" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="tfDireccionComplementaria" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="tfTelefono" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Teléfono 2" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="tfTelefono2" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Correo" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="tfCorreo" maxWidth="1.7976931348623157E308" promptText="correo@ejemplo.com" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Parentesco" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <TextField fx:id="tfParentesco" maxWidth="1.7976931348623157E308" promptText="AB/BA/..." GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Rol" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <TextField fx:id="tfRol" maxWidth="1.7976931348623157E308" promptText="VI" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                        <Label focusTraversable="false" styleClass="ficha-label" text="Observaciones"
                                               GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.valignment="TOP" />
                                        <TextArea fx:id="taObservaciones" styleClass="ficha-textarea" wrapText="true"
                                                  promptText="Apuntes internos, incidencias, notas..."
                                                  GridPane.columnIndex="1" GridPane.rowIndex="7" GridPane.valignment="TOP" />
                                      </children>
                                      <rowConstraints>
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                        <RowConstraints /><RowConstraints /><RowConstraints /><RowConstraints />
                                      </rowConstraints>
                                    </GridPane>
                                  </children>
                                </VBox>

                              </children>
                            </VBox>
                          </content>
                        </ScrollPane>
                      </center>

                      <!-- Widget ventas (derecha) -->
                      <right>
                        <VBox fx:id="panelVentas" styleClass="ventas-panel" prefWidth="210.0"
                              spacing="0.0" BorderPane.alignment="TOP_CENTER">
                          <padding>
                            <Insets top="10.0" right="8.0" bottom="10.0" left="8.0" />
                          </padding>
                          <children>
                            <Label text="Ventas" styleClass="ventas-titulo" />
                            <Separator />
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                        styleClass="ventas-scroll">
                              <content>
                                <VBox fx:id="vboxProductos" spacing="0.0" />
                              </content>
                            </ScrollPane>
                            <Separator />
                            <Label fx:id="lblTotalVentas" text="Total: 0,00 €" styleClass="ventas-total">
                              <VBox.margin><Insets top="6.0" /></VBox.margin>
                            </Label>
                          </children>
                        </VBox>
                      </right>

                      <!-- Botones inferiores -->
                      <bottom>
                        <HBox styleClass="ficha-actions" BorderPane.alignment="CENTER">
                          <children>
                            <Button fx:id="btnCopiarDatosPrevios" mnemonicParsing="false"
                                    onAction="#onCopiarDatosPrevios" prefHeight="26.0"
                                    styleClass="btn-copiar" text="Copiar datos previos" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnEliminar" mnemonicParsing="false"
                                    onAction="#onEliminarFicha" prefHeight="26.0"
                                    styleClass="btn-eliminar" text="Eliminar ficha" />
                            <Button fx:id="btnGuardar" defaultButton="true" mnemonicParsing="false"
                                    onAction="#onGuardarFicha" prefHeight="26.0"
                                    styleClass="btn-guardar" text="Guardar ficha" />
                          </children>
                        </HBox>
                      </bottom>

                    </BorderPane>
                  </HBox>
                </children>
              </AnchorPane>
            </content>
          </Tab>

          <!-- ++++++++++++++++++++++++++++++++++++++++++++++ -->
          <!-- PESTAÑA: VENTAS -->
          <!-- +++++++++++++++++++++++++++++++++++++++++++++++ -->
          <Tab text="Ventas">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0">
                <children>
                  <VBox spacing="10.0"
                        AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0"
                        AnchorPane.rightAnchor="0.0"
                        AnchorPane.topAnchor="0.0">
                    <padding>
                      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>

                    <!-- Barra superior: selector de fecha sincronizado -->
                    <HBox spacing="6.0" styleClass="left-panel">
                      <children>
                        <Button fx:id="btnVentasDiaAnterior" mnemonicParsing="false"
                                onAction="#onVentasDiaAnterior" text="◀" />
                        <DatePicker fx:id="dpFechaVentas" />
                        <Button fx:id="btnVentasDiaSiguiente" mnemonicParsing="false"
                                onAction="#onVentasDiaSiguiente" text="▶" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onActualizarVentas"
                                text="↻  Actualizar" styleClass="btn-copiar" />
                      </children>
                    </HBox>

                    <!-- Dos widgets lado a lado: Tarifas | Productos -->
                    <HBox spacing="10.0">

                      <!-- Widget Tarifas de estancia -->
                      <VBox spacing="8.0" styleClass="ficha-section" HBox.hgrow="ALWAYS" prefHeight="300.0">
                        <children>
                          <Label styleClass="ficha-title" text="Tarifas de estancia" />
                          <Separator />
                          <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                                      styleClass="ventas-scroll">
                            <content>
                              <ListView fx:id="lvTarifas" />
                            </content>
                          </ScrollPane>
                          <GridPane hgap="8.0" vgap="6.0">
                            <columnConstraints>
                              <ColumnConstraints minWidth="80.0" prefWidth="80.0" />
                              <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>
                            <children>
                              <Label text="Nombre" styleClass="ficha-label"
                                     GridPane.rowIndex="0" GridPane.columnIndex="0" />
                              <TextField fx:id="tfNombreTarifa" promptText="Ej: Estancia estándar"
                                         maxWidth="1.7976931348623157E308"
                                         GridPane.rowIndex="0" GridPane.columnIndex="1" />
                              <Label text="Precio €" styleClass="ficha-label"
                                     GridPane.rowIndex="1" GridPane.columnIndex="0" />
                              <TextField fx:id="tfPrecioTarifa" promptText="0.00"
                                         maxWidth="1.7976931348623157E308"
                                         GridPane.rowIndex="1" GridPane.columnIndex="1" />
