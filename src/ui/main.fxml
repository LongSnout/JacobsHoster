                              <Button text="Desactivar" onAction="#onDesactivarTarifa" styleClass="btn-eliminar" />
                            </children>
                          </HBox>
                        </children>
                      </VBox>

                      <!-- Widget Productos -->
                      <VBox spacing="8.0" styleClass="ficha-section" HBox.hgrow="ALWAYS" prefHeight="300.0">
